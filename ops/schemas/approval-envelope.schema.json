{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CryptoAutistic80/cedra-reflect/ops/schemas/approval-envelope.schema.json",
  "title": "Cedra Reflect detached transaction approval envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_scope", "status", "signature_namespace", "candidate_file", "candidate_sha256", "statement_file", "statement_sha256", "exact_address_artifacts_sha256", "public_profile_evidence_sha256", "public_role_candidate_sha256", "trusted_allowed_signers_sha256", "approvals"],
  "properties": {
    "schema_version": { "const": 1 },
    "evidence_scope": { "const": "detached-transaction-approval-envelope" },
    "status": { "const": "signed" },
    "signature_namespace": { "const": "cedra-reflect-testnet-release-v1" },
    "candidate_file": { "const": "transaction-candidate.json" },
    "candidate_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "statement_file": { "const": "approval-statement.json" },
    "statement_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "exact_address_artifacts_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "public_profile_evidence_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "public_role_candidate_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "trusted_allowed_signers_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "approvals": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identity", "key_fingerprint", "signature_file", "signature_sha256"],
        "properties": {
          "identity": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9@._+-]{0,127}$" },
          "key_fingerprint": { "type": "string", "pattern": "^SHA256:[A-Za-z0-9+/=]{43,44}$" },
          "signature_file": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
          "signature_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
