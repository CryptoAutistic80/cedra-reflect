{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cedra-reflect.invalid/schemas/sdk-review-attestation.schema.json",
  "title": "Independent Cedra SDK review attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_scope",
    "reviewed_at",
    "reviewer_identity",
    "independence_statement",
    "review_method",
    "review_report_reference",
    "decision",
    "sdk_review_pin_file",
    "sdk_review_pin_sha256",
    "sdk_package",
    "sdk_version",
    "npm_tarball_sha256",
    "sdk_package_tree_sha256",
    "sdk_package_file_count",
    "trusted_allowed_signers_sha256"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "evidence_scope": { "const": "independent-cedra-sdk-review-attestation" },
    "reviewed_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "reviewer_identity": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._@+-]{2,127}$" },
    "independence_statement": { "type": "string", "minLength": 40 },
    "review_method": { "type": "string", "minLength": 20 },
    "review_report_reference": { "type": "string", "minLength": 8 },
    "decision": { "const": "approved-for-testnet-candidate-assembly" },
    "sdk_review_pin_file": { "const": "reviewed-cedra-sdk-2.2.8.json" },
    "sdk_review_pin_sha256": { "$ref": "#/$defs/sha256" },
    "sdk_package": { "const": "@cedra-labs/ts-sdk" },
    "sdk_version": { "const": "2.2.8" },
    "npm_tarball_sha256": { "$ref": "#/$defs/sha256" },
    "sdk_package_tree_sha256": { "$ref": "#/$defs/sha256" },
    "sdk_package_file_count": { "type": "integer", "minimum": 1 },
    "trusted_allowed_signers_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
